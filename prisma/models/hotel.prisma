model Hotel {
  id          String   @id @default(cuid())
  name        String
  ownerId     String   @unique @map("owner_id")
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  wardId      String   @map("ward_id")
  ward        Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)
  
  longitude   Float
  latitude    Float

  type        HotelType
  description String?
  reviewPoints Float     @map("review_points")      // NOTE: this is a denormalized field and must be updated via triggers.
  numberOfReviews Int    @map("number_of_reviews") // NOTE: this is a denormalized field and must be updated via triggers. 

  checkInTime  DateTime @db.Time  @map("check_in_time")
  checkOutTime DateTime @db.Time  @map("check_out_time")
  breakfastAvailability Boolean @map("breakfast_availability")
  // TODO: may have videos
  imageUrls   String[]  // list of image URLs for the hotel

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  status           HotelStatus @default(ACTIVE)

  roomTypes        RoomType[]

  facilities       Facility[]
  favoritedBy      Favorite[]
  recentlyViewedBy RecentlyViewed[]
  bookings         Booking[]

  @@map("hotels")

  // TODO: add indexes for search optimization (e.g., by name, location, type)
  // @@index([])
}

enum HotelType {
  HOTEL
  MOTEL
  RESORT
  APARTMENT
  HOSTEL
  OTHER
}

enum HotelStatus {
  PENDING_APPROVAL
  REJECTED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FacilityType {
  HOTEL_SERVICES
  FOOD_AND_DRINK
  PUBLIC
  IN_ROOM
  ACCESSIBILITY
  OTHER
}

model Facility {
  id        String   @id @default(cuid())
  name      String   @unique
  // TODO: consider forcing iconUrl to be non-nullable and providing a default icon for each type, to ensure consistent UI/UX.
  iconUrl   String?  @map("icon_url") // optional icon URL for the facility
  type      FacilityType

  hotels    Hotel[]
  roomTypes RoomType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("facilities")
}

model Room {
  id               String   @id @default(cuid())
  name             String   @unique
  typeId           String   @map("type_id")
  type             RoomType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  imageUrls        String[]

  bookingRooms     BookingRoom[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("rooms")
}

enum BedType {
  SINGLE
  DOUBLE
  QUEEN
  KING
  TWIN
  OTHER
}

model RoomType {
  id        String   @id @default(cuid())
  hotelId          String   @map("hotel_id")
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name      String   @unique
  description String?

  rooms     Room[]

  adultCapacity    Int      @map("adult_capacity")
  childrenCapacity Int      @map("children_capacity")
  price            Decimal
  areaM2           Float
  bedType          BedType  @map("bed_type")

  facilities Facility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("room_types")
  @@index([hotelId])
}