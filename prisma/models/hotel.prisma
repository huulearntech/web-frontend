enum FacilityType {
  HOTEL_SERVICES
  FOOD_AND_DRINK
  PUBLIC
  IN_ROOM
  ACCESSIBILITY
  OTHER
}

model Facility {
  id        String   @id @default(cuid())
  name      String   @unique
  iconUrl   String?  @map("icon_url") // optional icon URL for the facility
  type      FacilityType

  hotels    Hotel[]
  rooms     Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("facilities")
}

model Room {
  id               String   @id @default(cuid())
  hotelId          String   @map("hotel_id")
  hotel            Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  name             String   @unique
  type             String
  adultCapacity    Int      @map("adult_capacity")
  childrenCapacity Int      @map("children_capacity")
  price            Decimal
  areaM2           Float
  bedType          BedType  @map("bed_type")
  imageUrls        String[]

  bookingRooms     BookingRoom[]
  facilities       Facility[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([hotelId])
  @@map("rooms")
}

enum BedType {
  SINGLE
  DOUBLE
  QUEEN
  KING
  TWIN
  OTHER
}